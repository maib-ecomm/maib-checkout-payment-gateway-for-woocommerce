{
  "name": "maib-ecomm/maib-checkout-payment-gateway-for-woocommerce",
  "description": "e-Commerce Checkout maib Payment Gateway for WooCommerce",
  "type": "wordpress-plugin",
  "keywords": [
    "WooCommerce",
    "Moldova",
    "maib",
    "e-commerce",
    "checkout",
    "bank",
    "payment",
    "gateway"
  ],
  "homepage": "https://github.com/maib-ecomm/maib-checkout-payment-gateway-for-woocommerce",
  "license": "GPL-3.0-or-later",
  "require": {
    "php": ">=7.2.5",
    "maib-ecomm/maib-checkout-sdk-php": "^v1.0.2",
    "ext-json": "*"
  },
  "config": {
    "platform": {
      "php": "7.2.5"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "automattic/jetpack-autoloader": true
    },
    "autoloader-suffix": "WC_Gateway_MAIB_Checkout",
    "optimize-autoloader": true
  },
  "prefer-stable": true
}