#. Plugin Name of the plugin
#: maib-payment-gateway-for-woocommerce.php
msgid "Maib Checkout Payment Gateway for WooCommerce"
msgstr ""

#. Plugin URI of the plugin
#: maib-payment-gateway-for-woocommerce.php
