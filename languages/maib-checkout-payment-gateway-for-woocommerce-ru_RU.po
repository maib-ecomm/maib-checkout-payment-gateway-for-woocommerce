#. Description of the plugin
#: maib-payment-gateway-for-woocommerce.php
msgid ""
"Accept Visa / Mastercard / Apple Pay / Google Pay / MIA Instant Payments on "
"your store with the Maib Checkout Payment Gateway for WooCommerce."
msgstr ""

#. Author of the plugin
#: maib-payment-gateway-for-woocommerce.php
msgid "maib"
msgstr ""

#. Author URI of the plugin
#: maib-payment-gateway-for-woocommerce.php
msgid "https://github.com/maib-ecomm"
msgstr ""

#: maib-payment-gateway-for-woocommerce.php:161
msgid "Enable/Disable"
msgstr "Включить/Отключить"

#: maib-payment-gateway-for-woocommerce.php:163
msgid "Enable Maib Checkout Payment Gateway"
msgstr "Включить Maib Checkout Payment Gateway"

#: maib-payment-gateway-for-woocommerce.php:168
msgid "Title"
msgstr "Заголовок"

#: maib-payment-gateway-for-woocommerce.php:170
msgid "Payment method title that the customer will see during checkout."
msgstr ""
"Название способа оплаты, которое покупатель увидит во время оформления "
"заказа."

#: maib-payment-gateway-for-woocommerce.php:172
#, fuzzy
#| msgid "Enable Maib Checkout Payment Gateway"
msgid "Maib Checkout Payment Gateway"
msgstr "Включить Maib Checkout Payment Gateway"

#: maib-payment-gateway-for-woocommerce.php:176
msgid "Description"
msgstr "Описание"

#: maib-payment-gateway-for-woocommerce.php:178
msgid "Payment method description that the customer will see during checkout."
msgstr ""
"Описание способа оплаты, которое покупатель увидит во время оформления "
"заказа."

#: maib-payment-gateway-for-woocommerce.php:180
msgid "Visa / Mastercard / Apple Pay / Google Pay / MIA Instant Payments"
msgstr ""

#: maib-payment-gateway-for-woocommerce.php:184
msgid "Test mode"
msgstr "Тестовый режим"

#: maib-payment-gateway-for-woocommerce.php:186
msgid "Enabled"
msgstr "Включено"

#: maib-payment-gateway-for-woocommerce.php:188
msgid ""
"Use Test or Live bank gateway to process the payments. Disable when ready to "
"accept live payments."
msgstr ""
"Для обработки платежей используйте тестовый или рабочий банковский шлюз. "
"Отключите эту функцию, когда будете готовы принимать реальные платежи."

#: maib-payment-gateway-for-woocommerce.php:193
msgid "Debug mode"
msgstr "Debug режим"

#: maib-payment-gateway-for-woocommerce.php:195
msgid "Enable logging"
msgstr "Включить логирование"

#: maib-payment-gateway-for-woocommerce.php:197
msgid "View logs"
msgstr "Смотреть журнал"

#: maib-payment-gateway-for-woocommerce.php:198
msgid ""
"Save debug messages to the WooCommerce System Status logs. Note: this may "
"log personal information. Use this for debugging purposes only and delete "
"the logs when finished."
msgstr ""
"Сохраняйте отладочные сообщения в журналы состояния системы WooCommerce. "
"Примечание: это может привести к записи личной информации. Используйте это "
"только для отладки и удалите журналы после завершения работы."

#: maib-payment-gateway-for-woocommerce.php:202
msgid "Order description"
msgstr "Описание заказа"

#. translators: %1$s - order ID, %2$ - order items summary
#: maib-payment-gateway-for-woocommerce.php:205
#, php-format
msgid ""
"Format: <code>%1$s</code> - Order ID, <code>%2$s</code> - Order items summary"
msgstr ""
"Формат: <code>%1$s</code> - Order ID, <code>%2$s</code> - Сводка по позициям "
"заказа"

#: maib-payment-gateway-for-woocommerce.php:206
msgid "Order description that the customer will see on the bank payment page."
msgstr ""
"Описание заказа, которое клиент увидит на странице банковского платежа."

#: maib-payment-gateway-for-woocommerce.php:211
msgid "Client ID <span class=\"required\">*</span>"
msgstr ""

#: maib-payment-gateway-for-woocommerce.php:213
#: maib-payment-gateway-for-woocommerce.php:220
#: maib-payment-gateway-for-woocommerce.php:227
msgid "It is available after payment profile setup."
msgstr "Эта функция становится доступна после настройки платежного профиля."

#: maib-payment-gateway-for-woocommerce.php:218
msgid "Client Secret <span class=\"required\">*</span>"
msgstr ""

#: maib-payment-gateway-for-woocommerce.php:225
msgid "Signature Key <span class=\"required\">*</span>"
msgstr ""

#: maib-payment-gateway-for-woocommerce.php:232
msgid "Order status"
msgstr "Статус заказа"

#: maib-payment-gateway-for-woocommerce.php:237
msgid "Payment completed"
msgstr "Платеж завершен"

#: maib-payment-gateway-for-woocommerce.php:241
msgid ""
"The completed order status after successful payment. By default: Processing."
msgstr ""
"Статус заказа после успешной оплаты: \"Завершено\". По умолчанию: \"В "
"обработке\"."

#: maib-payment-gateway-for-woocommerce.php:246
msgid "Payment failed"
msgstr "Платеж не выполнен"

#: maib-payment-gateway-for-woocommerce.php:250
msgid "Order status when payment failed. By default: Failed."
msgstr "Статус заказа при неудачной оплате. По умолчанию: Неудачная оплата."

#: maib-payment-gateway-for-woocommerce.php:272
msgid ""
"One or more of the required fields (Client ID, Client Secret, Signature Key) "
"is empty in Maib Checkout Payment Gateway settings."
msgstr ""
"В настройках платежного шлюза Maib Checkout одно или несколько обязательных "
"полей (Client ID, Client Secret, Signature Key) пусты."

#: maib-payment-gateway-for-woocommerce.php:290
msgid "Payment initiation failed via maib gateway, please try again later."
msgstr ""
"Инициирование платежа через платежный шлюз MAIB не удалось, пожалуйста, "
"попробуйте позже."

#: maib-payment-gateway-for-woocommerce.php:322
msgid "Refund not possible, payment ID missing in order data."
msgstr ""
"Возврат средств невозможен, в данных заказа отсутствует идентификатор "
"платежа."

#: maib-payment-gateway-for-woocommerce.php:331
msgid "Partial Refund has not implemented yet."
msgstr "Функция частичного возврата средств недоступна."

#: maib-payment-gateway-for-woocommerce.php:355
msgid "An error occurred in the system. Call 1313."
msgstr "Произошла ошибка в системе. Позвоните по номеру 1313."

#: maib-payment-gateway-for-woocommerce.php:361
msgid ""
"Refund was not completed due to technical error or timeout. Please contact "
"to support."
msgstr ""
"Возврат средств не был осуществлен из-за технической ошибки или истечения "
"времени ожидания. Пожалуйста, свяжитесь со службой поддержки."

#: maib-payment-gateway-for-woocommerce.php:519
msgid "Default status"
msgstr "Статус по умолчанию"

#: maib-payment-gateway-for-woocommerce.php:548
msgid "This Callback URL works and should not be called directly."
msgstr "Callback URL работает и не должен вызываться напрямую."

#. translators: %1$s - payment ID
#: maib-payment-gateway-for-woocommerce.php:649
#, php-format
msgid "Payment (%1$s) successful."
msgstr "Платеж (%1$s) прошел успешно."

#. translators: %1$s - payment ID
#: maib-payment-gateway-for-woocommerce.php:678
#, php-format
msgid "Payment (%1$s) failed."
msgstr "Платеж (%1$s) не удался."

